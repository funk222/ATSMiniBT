  ;; ════════════════════════════════════════════════════════════════
  ;; U2 - SI4732-A10 Broadcast Radio Receiver
  ;; QFN-20 3x3mm
  ;;
  ;; Pin summary (AN332 / SI4732-A10 datasheet):
  ;;  1 - FMIN       FM antenna input (AC coupled)
  ;;  2 - GND
  ;;  3 - VDD        1.8V digital supply (use LP2985 + divider or separate 1.8V LDO)
  ;;                 NOTE: SI4732 VDD = 1.8V; VDDO (IO logic) = can be 3.3V
  ;;  4 - VDDO       I/O voltage (connect to 3V3_ANALOG for 3.3V logic compatibility)
  ;;  5 - RCLK       Reference clock input (connect to X1 32.768kHz crystal)
  ;;  6 - GPO2/INT   Interrupt output (optional, connect to ESP32 GPIO if used)
  ;;  7 - RESET      Active-low reset (connect to SI_RESET via MCU)
  ;;  8 - SDIO       I2C SDA
  ;;  9 - SCLK       I2C SCL
  ;; 10 - GPO1       Can control MUTE (GPIO1 of SI4732, configured via firmware)
  ;; 11 - LOUT       Left audio output (analog)
  ;; 12 - ROUT       Right audio output (analog)
  ;; 13 - GND
  ;; 14 - VA         Analog supply 3.3V (connect to 3V3_ANALOG)
  ;; 15 - AMFMI      AM/FM select (firmware controlled via property)
  ;; 16 - LNA_EN     LNA enable (typically tied HIGH)
  ;; 17 - GND
  ;; 18 - XOUT       Crystal oscillator output (to X1)
  ;; 19 - XIN        Crystal oscillator input (from X1)
  ;; 20 - AMIN       AM antenna input (AC coupled)
  ;; ════════════════════════════════════════════════════════════════
  (symbol (lib_id "Radio:SI4732-A10") (at 120 120) (unit 1)
    (property "Reference" "U2" (at 120 90) (effects (font (size 1.5 1.5))))
    (property "Value" "SI4732-A10" (at 120 92) (effects (font (size 1.5 1.5))))
    (property "Footprint" "Package_DFN_QFN:QFN-20-1EP_3x3mm_P0.5mm_EP1.7x1.7mm" (at 0 0) (effects (font (size 1.27 1.27)) (hide)))
    (property "Description" "Si4732 AM/FM/SW/LW Radio Receiver, QFN-20, I2C control" (at 0 0) (effects (font (size 1.27 1.27)) (hide)))
    (property "Datasheet" "https://www.skyworksinc.com/-/media/Skyworks/SL/documents/public/application-notes/AN332.pdf" (at 0 0) (effects (font (size 1.27 1.27)) (hide)))
  )

