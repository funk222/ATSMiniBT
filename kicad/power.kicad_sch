  ;; U5 - BQ24075RGTR  Li-Po Charge Management  QFN-16 3x3mm
  ;; VBUS_USB (5V) → BQ24075 → VBAT (4.2V max, power-path mgmt)
  ;; ILIM = R10 = 2kΩ → I_charge = 890mV / 2kΩ = 445mA
  ;; VCC → VBAT via internal FET power path
