  ;; ════════════════════════════════════════════════════════════════
  ;; U3 - ES7243E Stereo I2S ADC
  ;; QFN-20 package
  ;;
  ;; Key pins:
  ;;  LINN / LINP  : Differential Left input  (use single-ended: LINP=signal, LINN=AGND via 0Ω)
  ;;  RINN / RINP  : Differential Right input
  ;;  MCLK         : Master clock (12.288MHz = 256*Fs, or use MCLK from ESP32)
  ;;                 NOTE: ESP32-WROVER-E can output MCLK on IO0 or I2S peripheral
  ;;                 Alternatively: ES7243E can run in slave mode, MCLK from BCLK*N
  ;;  BCLK         : Bit clock (I2S, slave: input from ESP32)
  ;;  LRCK         : Left/Right clock (I2S, slave: input from ESP32)
  ;;  SDOUT        : I2S serial data output → ESP32 I2S_DIN
  ;;  SDA / SCL    : I2C control (address configurable via ADDR pin)
  ;;  AVDD         : Analog supply (3V3_ANALOG)
  ;;  DVDD         : Digital supply (3V3_MAIN)
  ;;  PVDD         : PLL supply (3V3_ANALOG)
  ;;  AGND / DGND  : Analog and digital ground (single-point connect)
  ;;  VMID         : Internal reference (bypass cap to AGND)
  ;;  VREF         : Internal reference (bypass cap to AGND)
  ;; ════════════════════════════════════════════════════════════════
  (symbol (lib_id "Audio:ES7243E") (at 120 130) (unit 1)
    (property "Reference" "U3" (at 120 95) (effects (font (size 1.5 1.5))))
    (property "Value" "ES7243E" (at 120 97) (effects (font (size 1.5 1.5))))
    (property "Footprint" "Package_DFN_QFN:QFN-20-1EP_3x3mm_P0.5mm_EP1.7x1.7mm" (at 0 0) (effects (font (size 1.27 1.27)) (hide)))
    (property "Description" "ES7243E Stereo 24-bit I2S ADC, QFN-20, 8-192kHz" (at 0 0) (effects (font (size 1.27 1.27)) (hide)))
  )

