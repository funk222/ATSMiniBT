    (property "Footprint" "Connector_FFC-FPC:Hirose_FH12-8S-0.5SH_1x08-1MP_P0.50mm_Horizontal" (at 0 0) (effects (font (size 1.27 1.27)) (hide)))
    (property "Description" "2.4 inch 240x320 TFT, ST7789 controller, SPI 4-wire" (at 0 0) (effects (font (size 1.27 1.27)) (hide)))
  )

