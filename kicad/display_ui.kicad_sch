  ;; ════════════════════════════════════════════════════════════════
  ;; LCD1 - ST7789 TFT Display (240x320, SPI interface)
  ;; FPC connector, 8080/SPI selectable - use SPI mode
  ;;
  ;; Pin mapping (standard ST7789 module):
  ;;  VCC    → 3V3_MAIN
  ;;  GND    → GND
  ;;  SCL    → SPI_CLK  (IO15, VSPI SCLK)
  ;;  SDA    → SPI_MOSI (IO25, VSPI MOSI)
  ;;  RES    → LCD_RST  (IO14, active-low)
  ;;  DC     → LCD_DC   (IO12, data/command select)
  ;;  CS     → LCD_CS   (IO26, active-low)
  ;;  BLK    → LCD_BL   (IO13, PWM backlight control)
  ;; ════════════════════════════════════════════════════════════════
  (symbol (lib_id "Display:ST7789") (at 80 110) (unit 1)
    (property "Reference" "LCD1" (at 80 82) (effects (font (size 1.5 1.5))))
