  ;; ════════════════════════════════════════════════════════════════
  ;; U4 - MAX98357A I2S Digital Amplifier
  ;; DFN-16 2x2mm
  ;;
  ;; Key pins:
  ;;  BCLK    : I2S Bit clock (from ESP32 I2S_BCLK, same bus as ES7243E)
  ;;            NOTE: MAX98357A is a DAC+AMP; it takes I2S digital directly
  ;;            This means: SI4732 audio → ES7243E(ADC) → ESP32 → MAX98357A(DAC+AMP)
  ;;            This path adds ~5-10ms latency but is fully digital
  ;;            ALTERNATE: use SI4732 analog → NS4168 analog amp (simpler, lower latency)
  ;;            See note below for both options
  ;;  LRCLK   : I2S Left/Right clock
  ;;  DIN     : I2S Data in (from ESP32 I2S output DAC port)
  ;;  SD_MODE : Shutdown/mode pin:
  ;;            HIGH  = left channel
  ;;            LOW   = shutdown (mute)
  ;;            Float = left+right mix (typical for mono speaker)
  ;;            → Connect to AMP_SD (ESP32 GPIO33)
  ;;  PVDD    : Power supply 2.5-5.5V (connect to VBAT or 3V3_MAIN)
  ;;            For maximum power from 3.7V LiPo: connect to VBAT directly
  ;;  GND     : Ground
  ;;  OUT+/-  : BTL speaker output (differential, do NOT ground either pin)
  ;; ════════════════════════════════════════════════════════════════
  (symbol (lib_id "Audio:MAX98357A") (at 120 120) (unit 1)
    (property "Reference" "U4" (at 120 95) (effects (font (size 1.5 1.5))))
    (property "Value" "MAX98357AEWL+T" (at 120 97) (effects (font (size 1.5 1.5))))
    (property "Footprint" "Package_DFN_QFN:DFN-16-1EP_2x2mm_P0.25mm_EP1.12x1.12mm" (at 0 0) (effects (font (size 1.27 1.27)) (hide)))
    (property "Description" "MAX98357A 3.2W I2S Class-D Amplifier, DFN-16, SD_MODE software mute" (at 0 0) (effects (font (size 1.27 1.27)) (hide)))
  )

